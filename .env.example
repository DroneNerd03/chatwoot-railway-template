# ── Required ──
SECRET_KEY_BASE=change-me-run-openssl-rand-hex-64
FRONTEND_URL=https://YOUR_RAILWAY_DOMAIN.up.railway.app

# ── Auto-filled by Railway ──
# DATABASE_URL=
# REDIS_URL=

# ── Email (for invites & password reset) ──
MAILER_SENDER_EMAIL=noreply@yourdomain.com
SMTP_ADDRESS=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-sendgrid-api-key
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# ── Optional ──
# CHATWOOT_INBOX_EMAIL_REPLY_EMAIL=reply@yourdomain.com
# STORAGE_DRIVER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET=your-bucket
